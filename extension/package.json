{
  "name": "spinearn",
  "displayName": "SpinEarn — Earn from AI coding tools",
  "description": "Earn revenue from sponsored messages shown in Claude Code and Codex spinners while you code.",
  "version": "1.0.0",
  "publisher": "spinearn",
  "private": true,
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": ["Other"],
  "keywords": ["monetization", "claude code", "codex", "ads", "earnings"],
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "spinearn.signIn",
        "title": "SpinEarn: Sign In"
      },
      {
        "command": "spinearn.signOut",
        "title": "SpinEarn: Sign Out"
      },
      {
        "command": "spinearn.showDashboard",
        "title": "SpinEarn: Open Dashboard"
      },
      {
        "command": "spinearn.showStatus",
        "title": "SpinEarn: Show Status"
      }
    ],
    "configuration": {
      "title": "SpinEarn",
      "properties": {
        "spinearn.apiUrl": {
          "type": "string",
          "default": "https://api.spinearn.in",
          "description": "SpinEarn API base URL"
        },
        "spinearn.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable SpinEarn"
        },
        "spinearn.showInStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show earnings in VS Code status bar"
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.config.js",
    "watch": "node esbuild.config.js --watch",
    "package": "vsce package",
    "publish": "vsce publish",
    "test": "vitest run",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "nanoid": "^5.0.7"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.24.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "@vscode/vsce": "^3.2.1"
  }
}
