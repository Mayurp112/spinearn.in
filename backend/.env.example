# ─── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://spinads:spinads_dev_password@localhost:5432/spinads

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

# ─── JWT / Security ─────────────────────────────────────────
SECRET_KEY=your-super-secret-key-min-32-chars-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── Google OAuth2 ──────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── GitHub OAuth2 ──────────────────────────────────────────
GITHUB_CLIENT_ID=your-github-oauth-app-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-app-client-secret

# ─── Stripe ─────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
STRIPE_CONNECT_CLIENT_ID=ca_your_stripe_connect_client_id

# ─── Revenue Share ───────────────────────────────────────────
PLATFORM_REVENUE_SHARE=0.50

# ─── URLs ───────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# ─── Environment ────────────────────────────────────────────
ENVIRONMENT=development

# ─── Postgres (for docker-compose) ──────────────────────────
POSTGRES_DB=spinads
POSTGRES_USER=spinads
POSTGRES_PASSWORD=spinads_dev_password
